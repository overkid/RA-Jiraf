{
  "name": "ra-jiraf-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "npm run dev -w @ra-jiraf/backend",
    "dev:frontend": "npm run dev -w @ra-jiraf/frontend",
    "build": "npm run build -w @ra-jiraf/backend && npm run build -w @ra-jiraf/frontend"
  }
}
